# Copy this file to `e2e/.env` and fill in real values.
# The Playwright runner reads it automatically (see playwright.config.ts).

# URL of the running UI (Next.js dev server or staging instance).
E2E_BASE_URL=http://localhost:3000

# URL of the running API (used by request-level helpers and seed steps).
# Optional. If unset, request helpers fall back to E2E_BASE_URL.
E2E_API_BASE_URL=http://localhost:8080

# Seed credentials for an existing tenant owner / admin.
# These are required for any spec that hits a tenant-scoped page.
E2E_USER_EMAIL=admin@example.com
E2E_USER_PASSWORD=changeme

# Slug of the tenant the seed user belongs to.
E2E_TENANT_SLUG=acme

# Optional locale override (defaults to en-US).
# E2E_LOCALE=vi-VN
